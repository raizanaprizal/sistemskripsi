# ============================================================
# .env.example — Contoh Environment Variables
# Sistem Pemilihan Vendor PT Bio Farma (Persero)
#
# CARA PENGGUNAAN:
# 1. Copy file ini menjadi ".env" (tanpa .example)
# 2. Isi nilai sesuai konfigurasi Supabase Anda
# 3. JANGAN commit file .env ke Git!
#
# Di Vercel: tambahkan variabel ini di:
#   Project Settings → Environment Variables
# ============================================================

# ── Supabase PostgreSQL Connection ───────────────────────────
# Didapat dari: Supabase Dashboard → Project Settings → Database
DB_HOST=db.XXXXXXXXXXXXXXXX.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASS=your_supabase_db_password_here

# ── Base URL Aplikasi ─────────────────────────────────────────
# Isi dengan URL Vercel deployment Anda setelah deploy
# Contoh: https://sistemskripsi.vercel.app
# Kosongkan untuk auto-detect dari HTTP_HOST
BASE_URL=
